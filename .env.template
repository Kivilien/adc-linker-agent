# LLM Provider (choose one)
# Option A: DeepSeek (recommended for Chinese users)
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com  # default, change if using proxy

# Option B: Anthropic Claude
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-fable-5
# ANTHROPIC_API_KEY=sk-ant-...

# API Authentication (for production use)
# Set this to require API key on POST /agent/query
# Leave empty for dev mode (no auth required)
# ADC_API_KEY=your-secret-api-key

# Synthesis model (defaults to LLM_MODEL if not set)
# Use a different model for the final synthesis step (e.g., more capable)
# SYNTHESIS_MODEL=deepseek-chat

# Optional: server config
# MCP_HOST=0.0.0.0
# MCP_PORT=8000
